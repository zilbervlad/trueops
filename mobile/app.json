{
  "expo": {
    "name": "TrueOps",
    "slug": "trueops-mobile",
    "version": "1.0.4",
    "orientation": "portrait",
    "scheme": "trueops",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trueops.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationsUsageDescription": "TrueOps sends operations alerts, checklist updates, maintenance updates, and important store messages.",
        "NSCameraUsageDescription": "TrueOps uses the camera to attach store photos to Supervisor Visit Reports.",
        "NSPhotoLibraryUsageDescription": "TrueOps uses your photo library to attach store photos to Supervisor Visit Reports."
      },
      "buildNumber": "8",
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "com.trueops.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "versionCode": 3
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f172a"
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "messages"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow TrueOps to select photos for Supervisor Visit Reports.",
          "cameraPermission": "Allow TrueOps to take photos for Supervisor Visit Reports."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "79c63e1a-94e6-4de2-8087-9536582f5f8d"
      }
    },
    "icon": "./assets/images/icon.png",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/79c63e1a-94e6-4de2-8087-9536582f5f8d"
    }
  }
}
