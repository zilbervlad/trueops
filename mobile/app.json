{
  "expo": {
    "name": "TrueOps",
    "slug": "trueops-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "trueops",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trueops.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.trueops.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "79c63e1a-94e6-4de2-8087-9536582f5f8d"
      }
    }
  }
}
